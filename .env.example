APP_NAME="YVE Agency"
APP_ENV=development
APP_URL=http://localhost:8000
APP_KEY=

# Banco de dados
DB_ADAPTER=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=yve_agency
DB_USER=postgres
DB_PASS=

# Sessão
SESSION_LIFETIME=7200
SESSION_NAME=yve_session

# Logs
LOG_CHANNEL=daily
LOG_LEVEL=debug

# E-mail SMTP
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@yveagency.com
MAIL_FROM_NAME="YVE Agency"

# OpenAI / IA
AI_PROVIDER=openai
AI_API_KEY=
AI_MODEL=gpt-4o
AI_MAX_TOKENS=2000

# Evolution API (WhatsApp)
EVOLUTION_BASE_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=

# Meta / Facebook
META_APP_ID=
META_APP_SECRET=
META_API_VERSION=v19.0

# Google Drive
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

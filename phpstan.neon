parameters:
    level: 6
    paths:
        - app
    excludePaths:
        - app/Support/helpers.php
    treatPhpDocTypesAsCertain: false
    ignoreErrors:
        # Ainda não anotamos os value-types de todo array (substitui a opção
        # deprecada checkMissingIterableValueType). Meta futura: tipar e remover.
        - identifier: missingType.iterableValue
